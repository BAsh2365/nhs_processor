# NHS Medical Document Processor — Environment Configuration
# Copy this file to .env and fill in values for your deployment.

# ── Authentication ────────────────────────────────────────────────────
# Comma-separated list of valid API keys. If empty, auth is DISABLED.
# Generate a key: python -c "import secrets; print(secrets.token_urlsafe(32))"
NHS_API_KEYS=

# Flask session signing key (generate once, keep secret)
# python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=

# ── HTTPS / TLS ──────────────────────────────────────────────────────
# Only needed if running TLS directly (not behind a reverse proxy)
# TLS_CERT_PATH=/path/to/fullchain.pem
# TLS_KEY_PATH=/path/to/privkey.pem

# ── Model Configuration ──────────────────────────────────────────────
# Force CPU even if GPU is available (useful for debugging)
# FORCE_CPU=1

# Hugging Face cache directory (default: ~/.cache/huggingface)
# HF_HOME=/app/model_cache
