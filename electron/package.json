{
  "name": "nhs-cardio-triage-desktop",
  "version": "1.0.0",
  "description": "Desktop app for NHS Medical Document Processor",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "author": "NHS Cardio Triage Team",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "build": {
    "appId": "com.nhs-cardio-triage.desktop",
    "productName": "NHS Cardio Triage AI",
    "files": [
      "main.js",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../ui/out",
        "to": "ui/out"
      },
      {
        "from": "../backend",
        "to": "backend"
      },
      {
        "from": "../frontend",
        "to": "frontend"
      }
    ]
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  }
}
